# Copy this file to ".env.local" and set real values. Next.js loads .env.local automatically.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Variables exposed to the browser must use the NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_APP_URL=http://localhost:3002

# API base URL (no trailing slash). Login: POST {base}/auth/login
NEXT_PUBLIC_API_URL=http://localhost:4001

# Server-only secrets (no NEXT_PUBLIC_ prefix — never exposed to the client)
# API_SECRET_KEY=
